{
  "name": "@mailwarm/api",
  "version": "0.1.0",
  "scripts": {
    "dev": "tsx watch --env-file .env src/server.ts",
    "dev:workers": "tsx watch --env-file .env src/workers/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:workers": "node dist/workers/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@apollo/server": "^4.10.0",
    "@as-integrations/fastify": "^2.1.1",
    "@aws-sdk/client-route-53": "^3.525.0",
    "@azure/arm-dns": "^5.1.0",
    "@azure/identity": "^4.0.0",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.0",
    "@fastify/rate-limit": "^9.1.0",
    "@mailwarm/database": "workspace:*",
    "@mailwarm/shared": "workspace:*",
    "@workos-inc/node": "^8.0.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.3.0",
    "cloudflare": "^3.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.8.5",
    "graphql": "^16.8.1",
    "imapflow": "^1.2.18",
    "ioredis": "^5.3.2",
    "node-forge": "^1.3.1",
    "nodemailer": "^6.9.10",
    "pino": "^8.19.0",
    "stripe": "^14.18.0",
    "xml2js": "^0.6.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.11.0",
    "@types/node-forge": "^1.3.10",
    "@types/nodemailer": "^6.4.14",
    "@types/xml2js": "^0.4.14",
    "pino-pretty": "^11.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
